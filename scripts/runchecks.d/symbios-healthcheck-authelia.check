# Healthcheck for authelia (HTTP health endpoint)
g_check_file="${g_tmp}/symbios-healthcheck-authelia"
if [[ -f "$g_check_file" ]] && find "$g_check_file" -mmin -5 | grep -q "$g_check_file"
then
  return 2>/dev/null || true
fi
date > "$g_check_file"
if ! docker exec authelia wget -q -O /dev/null --timeout=10 http://localhost:9091/api/health 2>/dev/null
then
  g_echo_error "Healthcheck failed for authelia: HTTP health endpoint unreachable"
fi
