# Healthcheck for runchecks daemon itself
g_check_file="${g_tmp}/symbios-healthcheck-runchecks"
if [ -f "$g_check_file" ] && find "$g_check_file" -mmin -5 | grep -q "$g_check_file"
then
  return 2>/dev/null || true
fi
date > "$g_check_file"
if ! systemctl is-active runchecks.service >/dev/null 2>&1
then
  g_echo_error "Healthcheck failed for runchecks: service not active"
fi
