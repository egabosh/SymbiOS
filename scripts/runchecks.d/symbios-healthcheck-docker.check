# Healthcheck for docker daemon
g_check_file="${g_tmp}/symbios-healthcheck-docker"
if [[ -f "$g_check_file" ]] && find "$g_check_file" -mmin -5 | grep -q "$g_check_file"
then
  return 2>/dev/null || true
fi
date > "$g_check_file"
if ! docker info >/dev/null 2>&1
then
  g_echo_error "Healthcheck failed for docker: daemon not responding"
fi
